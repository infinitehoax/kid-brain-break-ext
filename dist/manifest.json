{
  "manifest_version": 3,
  "name": "KidBrainBreak",
  "version": "2.1.0",
  "description": "Fun educational brain breaks every 30 minutes — spinning wheel, IPA, YouTube & 13 question types!",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": [
        "injected-ui/popup.html",
        "injected-ui/popup.css",
        "injected-ui/popup.js",
        "questions.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "KidBrainBreak Settings",
    "default_popup": "settings-popup.html"
  }
}
